{
  "id": "S2DBROW",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "BROWSE ─ ENTRY PANEL",
    "version_var": "ZSHRTVER"
  },
  "type": "browse",
  "body": {
    "rows": [
      { "type": "command",   "variable": "ZCMD" },
      { "type": "blank" },
      { "type": "text",      "content": "PROJECT FILE:" },
      { "type": "field_row",
        "fields": [
          { "type": "text",  "content": "DRIVE" },
          { "type": "input", "variable": "Z", "width": 2, "field_connector": true }
        ]
      },
      { "type": "field_row",
        "fields": [
          { "type": "text",  "content": "PATH" },
          { "type": "input", "variable": "ZFPATH1", "field_connector": true }
        ]
      },
      { "type": "field_row",
        "fields": [
          { "type": "text",  "content": "+PATH" },
          { "type": "input", "variable": "ZFPATH2", "field_connector": true }
        ]
      },
      { "type": "field_row",
        "fields": [
          { "type": "text",  "content": "+PATH" },
          { "type": "input", "variable": "ZFPATH3", "field_connector": true }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          { "type": "text", "content": "NAME" },
          { "type": "input", "variable": "ZFNAME", "field_connector": true }
        ]
      },
      { "type": "text", "content": "(Blank or pattern for file selection list)" },
      { "type": "blank" },
      { "type": "field_row",
        "fields": [
          { "type": "text", "content": "SYSTEM CUR DIR:" },
          { "type": "output", "variable": "ZCURDIR" }
        ]
      },
      { "type": "blank" },
      { "type": "text", "content": "SYSTEM FILE SPECIFICATION:" },
      { "type": "input", "variable": "ZFSPEC", "field_connector": true },
      { "type": "blank" },
      { "type": "field_row",
        "fields": [
          { "type": "text", "content": "PROFILE" },
          { "type": "input", "variable": "ZPROF", "width": 8, "field_connector": true },
          { "type": "text", "content": "+ (Blank defaults to file extension)" }
        ]
      },
      { "type": "blank" }
    ]
  },
  "init": {
    "help_panel": "S2R10000",
    "zvars": [ "ZFDRIVE" ]
  },
  "metadata": {
    "source_file": "S2DBROW.PAN",
    "category": "browse"
  }
}