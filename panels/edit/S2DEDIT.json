{
  "id": "S2DEDIT",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT ─ ENTRY PANEL",
    "version_var": "ZSHRTVER"
  },
  "type": "edit",
  "attributes": {
    "^": {
      "type": "INPUT",
      "intensity": "high",
      "caps": false,
      "scroll": true,
      "justification": "left"
    }
  },
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "PROJECT FILE:"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "DRIVE"
          },
          {
            "type": "input",
            "variable": "Z",
            "width": 2,
            "field_connector": true
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "PATH"
          },
          {
            "type": "input",
            "variable": "ZFPATH1",
            "attribute": "^",
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+PATH"
          },
          {
            "type": "input",
            "variable": "ZFPATH2",
            "attribute": "^",
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+PATH"
          },
          {
            "type": "input",
            "variable": "ZFPATH3",
            "attribute": "^",
            "field_connector": true
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "NAME"
          },
          {
            "type": "input",
            "variable": "ZFNAME",
            "attribute": "^",
            "field_connector": true
          }
        ]
      },
      {
        "type": "text",
        "content": "(Blank or pattern for file selection list)"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "SYSTEM CUR DIR:"
          },
          {
            "type": "output",
            "variable": "ZCURDIR"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SYSTEM FILE SPECIFICATION:"
      },
      {
        "type": "input",
        "variable": "ZFSPEC",
        "attribute": "^",
        "field_connector": true
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "PROFILE"
          },
          {
            "type": "input",
            "variable": "ZPROF",
            "width": 8,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+ (Blank defaults to file extension)"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "MAX RECL"
          },
          {
            "type": "input",
            "variable": "PLR",
            "width": 5,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (1.."
          },
          {
            "type": "output",
            "variable": "ZMAXLREC"
          },
          {
            "type": "text",
            "content": ", new profile default ="
          },
          {
            "type": "output",
            "variable": "ZPMAXREC"
          },
          {
            "type": "text",
            "content": ")"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "IMACRO"
          },
          {
            "type": "input",
            "variable": "PIMAC",
            "width": 8,
            "field_connector": true
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "XMACRO"
          },
          {
            "type": "input",
            "variable": "PXMAC",
            "width": 8,
            "field_connector": true
          }
        ]
      }
    ]
  },
  "init": {
    "help_panel": "S2R20000",
    "zvars": [
      "ZFDRIVE"
    ],
    "conditionals": [
      {
        "condition": "&ZFSPEC != ''",
        "then_assignments": {},
        "then_cursor": "ZFSPEC"
      }
    ]
  },
  "proc_section": {
    "validations": [
      {
        "field": "ZFDRIVE",
        "rules": [
          {
            "type": "picture",
            "format": "A:"
          }
        ]
      },
      {
        "field": "PLR",
        "rules": [
          {
            "type": "numeric",
            "range": {
              "min": 1,
              "max": "ZMAXLREC"
            }
          }
        ]
      }
    ]
  },
  "metadata": {
    "source_file": "S2DEDIT.PAN",
    "category": "edit",
    "copyright": "(C) Copyright 1984-1994, Command Technology Corporation.  All Rights Reserved."
  }
}