{
  "id": "S2CHNG04",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "SUPERC FILE COMPARISON",
    "version_var": "ZSHRTVER",
    "prefix": "CHANGES"
  },
  "type": "changelog",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SPF/PC has a new file comparison utility, Panel 3.I.  You can"
      },
      {
        "type": "text",
        "content": "compare files by line or by byte. You can get a differences report"
      },
      {
        "type": "text",
        "content": "in detail, summary, or both.  The report can be directed to a"
      },
      {
        "type": "text",
        "content": "temporary BROWSE file, a specific file, or to the logical printer."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You can control the comparison operations in a variety of areas:"
      },
      {
        "type": "text",
        "content": "capitalization, columns, and numbering options."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "File comparison can also compare list of files, comparing all"
      },
      {
        "type": "text",
        "content": "similarly named files as determined by the specified file"
      },
      {
        "type": "text",
        "content": "specifications."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "For further details see:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SPF/PC User Guide and Reference,"
      },
      {
        "type": "text",
        "content": "SUPERC, Utility Option 3.I .......... Page 12-23"
      }
    ]
  },
  "proc_section": {
