            "type": "text",
            "content": "The following are enhancements SPF/PC Version"
          },
          {
            "type": "output",
            "variable": "ZSHRTVER"
          },
          {
            "type": "text",
            "content": "."
          }
        ]
      },
      {
        "type": "text",
        "content": "For specific information, enter the desired number and press 3270-ENTER."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "^  1 + Modifiable Panels                ^ 12 + 132 Column Support"
      },
      {
        "type": "text",
        "content": "^  2 + UNDO/REDO                        ^ 13 + 64000 Byte Record Support"
      },
      {
        "type": "text",
        "content": "^  3 + Program Source Colorization      ^ 14 + Edit Read-only Files"
      },
      {
        "type": "text",
        "content": "^  4 + SUPERC File Comparison           ^ 15 + Enhanced CUT and PASTE"
      },
      {
        "type": "text",
        "content": "^  5 + New SPLIT Modes                  ^ 16 + 32 Bit Executables"
      },
      {
        "type": "text",
        "content": "^  6 + Enhanced File Selection Lists    ^ 17 + New SPFPC Command Parameters"
      },
      {
        "type": "text",
        "content": "^  7 + Extended File Specifications     ^ 18 + New Primary Commands"
      },
      {
        "type": "text",
        "content": "^  8 + Print Setup Enhancements         ^ 19 + Optional COBOL Source Analyst"
      },
      {
        "type": "text",
        "content": "^  9 + PFSHOW Support                   ^ 20 + Optional XDB Interface"
      },
      {
        "type": "text",
        "content": "^ 10 + Scrollable Input Fields          ^ 21 + Optional MVS Access"
      },
      {
        "type": "text",
        "content": "^ 11 + Full Mouse Support               ^ 22 + Optional Micro Focus Shell"
      }
    ]
  },
