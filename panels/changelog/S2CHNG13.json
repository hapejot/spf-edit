{
  "id": "S2CHNG13",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "64000 BYTE RECORD SUPPORT",
    "version_var": "ZSHRTVER",
    "prefix": "CHANGES"
  },
  "type": "changelog",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You can now can read files with record lengths up to 64000 bytes."
      },
      {
        "type": "text",
        "content": "This extension is especially useful when editing large files"
      },
      {
        "type": "text",
        "content": "downloaded from the mainframe, where the practical record length"
      },
      {
        "type": "text",
        "content": "limit is 32700."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SPF/PC loads files with small record lengths (<4096 bytes) more"
      },
      {
        "type": "text",
        "content": "efficiently than larger ones, however.  Therefore, if you are going"
      },
      {
        "type": "text",
        "content": "to edit only small files, leave the MAXIMUM RECORD LENGTH field of"
      },
      {
        "type": "text",
        "content": "Panel 0.5 set to a smaller number.  This insures SPF/PC that it"
      },
      {
        "type": "text",
        "content": "will never have to deal will a wider file, and can maintain small,"
      },
      {
        "type": "text",
        "content": "efficient buffering schemes."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "For further details see:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SPF/PC User Guide and Reference,"
      },
      {
        "type": "text",
        "content": "Profile Definition Panel .................. Page 9-31"
      }
    ]
  },
  "proc_section": {
    "assignments": {
      "ZSEL": "UP"
    }
  },
