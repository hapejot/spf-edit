        "fields": [
          { "type": "text", "content": "  Tab size  . . . . . ." },
          { "type": "input", "variable": "ZTABS", "width": 4 }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          { "type": "text", "content": "  Nulls mode  . . . . ." },
          { "type": "input", "variable": "ZNULLS", "width": 1 },
          { "type": "text", "content": "(Y or N)" }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          { "type": "text", "content": "  Caps mode . . . . . ." },
          { "type": "input", "variable": "ZCAPS", "width": 1 },
          { "type": "text", "content": "(Y or N)" }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          { "type": "text", "content": "  Number mode . . . . ." },
          { "type": "input", "variable": "ZNUMS", "width": 1 },
          { "type": "text", "content": "(Y or N)" }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Display options:"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
