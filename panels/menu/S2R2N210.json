{
  "id": "S2R2N210",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - SCREATE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to create an original external file with the contents"
      },
      {
        "type": "text",
        "content": "of the selection."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "SCREATE [ file-name ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Selections are made with the mouse. The selection is not deleted from"
      },
      {
        "type": "text",
        "content": "the file. If you do not specify a file name, a dialog panel is pres-"
      },
      {
        "type": "text",
        "content": "ented which enables you to enter the target file name."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If the file already exists, SCREATE will not overwrite it. To overwrite"
      },
      {
        "type": "text",
        "content": "the file with the selection use SREPLACE."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
