{
  "id": "S2R2L340",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - MD",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Converts a NOTE or MSG line to a data line."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "MD[number]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command may be specified with or without a number.  If a number"
      },
      {
        "type": "text",
        "content": "is specified, the next number of lines will be converted to data."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "=NOTE= This is a note line."
      },
      {
        "type": "text",
        "content": "MD TE= This is the second note line."
      },
      {
        "type": "text",
        "content": "000001 FOR HIS CAP AND HE CALLED FOR HIS BOWL"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Results"
      },
      {
        "type": "text",
        "content": "=NOTE= This is a note line."
      },
      {
        "type": "text",
        "content": "000001 This is the second note line."
      },
      {
        "type": "text",
        "content": "000002 FOR HIS CAP AND HE CALLED FOR HIS BOWL"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
