{
  "id": "S2R2N013",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "GENERAL COMMAND - SPLITV",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to split the screen vertically at the midpoint into"
      },
      {
        "type": "text",
        "content": "two complete SPF/PC sessions."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "SPLITV"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Issuing SPLITV does one of two things:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "1. If only one session has been started, SPF/PC saves the current"
      },
      {
        "type": "text",
        "content": "session, splits the screen vertically at the midpoint, starts a"
      },
      {
        "type": "text",
        "content": "second session, and makes it the active session."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "2. If the second session has been started, SPF/PC splits the screen"
      },
      {
        "type": "text",
        "content": "vertically at the midpoint, and swaps to the other session."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
