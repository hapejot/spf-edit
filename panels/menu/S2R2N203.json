{
  "id": "S2R2N203",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - COMPARE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to compare the file being edited to an external file."
      },
      {
        "type": "text",
        "content": "After COMPARE is complete, the differences are integrated into the"
      },
      {
        "type": "text",
        "content": "current file as \"==INS>\" and \"==DEL>\" lines."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "COMPARE [ file-name ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If \"file-name\" is not specified, an entry panel is presented which"
      },
      {
        "type": "text",
        "content": "allows you to specify an individual file or generate a select list"
      },
      {
        "type": "text",
        "content": "from which you can select an individual file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "See SUPERC Utility (3.1) for details on other fields in the SUPERC"
      },
      {
        "type": "text",
        "content": "entry panel."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
