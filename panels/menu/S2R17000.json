  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The BROWSE commands entered in the COMMAND field of the BROWSE display"
      },
      {
        "type": "text",
        "content": "screen are listed below."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The following topics may be selected by number:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "1 + BROWSE   BROWSE another file while within BROWSE"
      },
      {
        "type": "text",
        "content": "2 + COLUMNS  to display column numbers on the display"
      },
      {
        "type": "text",
        "content": "3 + FIND     to find and display a character string"
      },
      {
        "type": "text",
        "content": "4 + HEX      to set HEX display mode on or off"
      },
      {
        "type": "text",
        "content": "5 + RESET    to clear column numbers from the display"
      },
