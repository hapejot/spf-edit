      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Replaces an existing file using all or part of the file currently"
      },
      {
        "type": "text",
        "content": "being edited."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "REPLACE [filename] [range]"
      },
      {
        "type": "text",
        "content": "REPL"
      },
      {
        "type": "text",
        "content": "REP"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "The REPLACE primary command works identically to the CREATE primary"
      },
      {
        "type": "text",
        "content": "command with the exception that if the file already exists, it is"
      },
      {
        "type": "text",
        "content": "replaced."
      },
