      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Scroll the screen to its furthest extreme up, down, left, or"
      },
      {
        "type": "text",
        "content": "right."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
