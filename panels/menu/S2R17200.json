      {
        "type": "text",
        "content": "The COLUMNS command displays a columns line on the first line of the"
      },
      {
        "type": "text",
        "content": "data area."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "COMMAND  columns       +       causes display of a columns line"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The columns line remains at the top of the data display area regardless"
      },
      {
        "type": "text",
        "content": "of scrolling in any direction, until the RESET command clears it."
