  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - LCOMMAND",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Specifies whether the line command field is present or not."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "LCOMMAND [ ON | OFF ]"
      },
      {
        "type": "text",
        "content": "LCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If ON is specified, the line command field is present."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If OFF is specified, the line command field is not present. In this"
      },
      {
        "type": "text",
        "content": "case it is necessary to map specific line command actions to PF keys"
      },
      {
        "type": "text",
        "content": "(or other control keys) to be able to execute those line commands."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "See the KEYS primary command description or Keyboard Mapping Option"
      },
      {
        "type": "text",
        "content": "0.K for a description of hoe to map key sequences to specific line"
      },
      {
        "type": "text",
        "content": "command actions."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
