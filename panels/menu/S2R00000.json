{
  "id": "S2R00000",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "TABLE OF CONTENTS",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "attributes": {
    "^": {
      "type": "PROT",
      "intensity": "high",
      "mouse": true
    }
  },
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "SPF/PC VERSION"
          },
          {
            "type": "output",
            "variable": "ZSHRTVER"
          }
        ]
      },
      {
        "type": "text",
        "content": "GENERAL HELP AND TUTORIAL SYSTEM"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The following topics may be selected by entering a one character selection"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "code in the OPTION field on line 2 followed by pressing the"
          },
          {
            "type": "text",
            "content": "ENTER+key."
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "G +GENERAL   - Display general usage information on SPF/PC"
          },
          {
            "type": "output",
            "variable": "ZSHRTVER"
          },
          {
            "type": "text",
            "content": "."
          }
        ]
      },
      {
        "type": "text",
        "content": "1 +BROWSE    - Information on the BROWSE primary commands."
      },
      {
        "type": "text",
        "content": "2 +EDIT      - Information on the EDIT primary and line commands."
      },
      {
        "type": "text",
        "content": "3 +UTILITIES - Descriptions of the utilities available on panel 3."
      },
      {
        "type": "text",
        "content": "4 +CONFIGURE - Information on configuring your SPF/PC environment."
      },
      {
        "type": "text",
        "content": "I +INDEX     - Alphabetical list of available information panels."
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "For more information on using the SPF/PC HELP system, hit"
          },
          {
            "type": "text",
            "content": "ENTER+without"
          }
        ]
      },
      {
        "type": "text",
        "content": "entering any options."
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "To exit HELP, enter the"
          },
          {
            "type": "text",
            "content": "END+primary command.  Typically,"
          },
          {
            "type": "text",
            "content": "END+is assigned"
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "the"
          },
          {
            "type": "text",
            "content": "F3+function key."
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+for more information)"
          }
        ]
      }
    ]
  },
  "proc_section": {
    "navigation": {
      "source_variable": "ZCMD",
      "routes": [
        {
          "value": "&ZCMD",
          "action": {
            "type": "panel",
            "target": "."
          }
        }
      ]
    }
  },
