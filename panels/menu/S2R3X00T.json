{
  "id": "S2R3X00T",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE LIST LINE COMMAND - T",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to generate a recersive tree of a subdirectory."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "T"
      },
      {
        "type": "text",
        "content": "TT"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Type a 'T' next to the directory you want to traverse.  This"
      },
      {
        "type": "text",
        "content": "command, by default, may be use only from 3.4 or 3.X select lists."
      },
      {
        "type": "text",
        "content": "The EXTENDED LIND COMMANDS field of panel 0.5 may be toggled to"
      },
      {
        "type": "text",
        "content": "allow this command from any file list."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If you select a subdirectory with T, the traversed file list is"
      },
      {
        "type": "text",
        "content": "generated where any file selected from it may be selected."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "NAME        SIZE    DATE    TIME"
      },
      {
        "type": "text",
        "content": "T  STUFF      <DIR>  01-25-91 10:56a"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
  "proc_section": {
    "navigation": {
      "source_variable": "ZCMD",
      "routes": []
    }
  },
