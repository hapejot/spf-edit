{
  "id": "S2R2N303",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE SELECTION LIST",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "This is a primary command. Use this command to INCLUDE a specific group"
      },
      {
        "type": "text",
        "content": "of files from the current select list and EXCLUDE all others."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "INCLUDE file-spec"
      },
      {
        "type": "text",
        "content": "INC     [ file-spec2 ]"
      },
      {
        "type": "text",
        "content": "[ file-spec...]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This is the inverse of EXCLUDE. Standard system wild card characters"
      },
      {
        "type": "text",
        "content": "are accepted."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You can specify multiple file specifications. This will create a select"
      },
      {
        "type": "text",
        "content": "list of all matching files."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
