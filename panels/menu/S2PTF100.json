  "id": "S2PTF100",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "TERMINAL FUNCTION - [DEL-END-OF-DATA]",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Delete all the data to the right of the current cursor position."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "[DEL-END-OF-DATA]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "All the data to the right of the current cursor position,"
      },
      {
        "type": "text",
        "content": "inclusive, is overwritten with blanks.  Extends all the way to"
      },
      {
        "type": "text",
        "content": "the end of the current unprotected field, or all the way to the"
      },
      {
        "type": "text",
        "content": "end of the current record."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Unlike the mainframe, [DEL-END-OF-DATA] deletes data beyond tab"
      },
      {
        "type": "text",
        "content": "spots."
      },
