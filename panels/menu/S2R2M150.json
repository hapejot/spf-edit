      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Any changes made during an edit session are cancelled."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If the SAVE command was used before CANCEL, edit changes made up to"
      },
      {
        "type": "text",
        "content": "the SAVE are not cancelled."
