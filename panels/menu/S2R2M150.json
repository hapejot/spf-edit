        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Cancels editing of current file, abandoning any changes made during"
      },
      {
        "type": "text",
        "content": "the EDIT session."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
