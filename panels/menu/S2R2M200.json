{
  "id": "S2R2M200",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - LEVEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Assigns a modification level to the current file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "LEVEL number"
      },
      {
        "type": "text",
        "content": "LEV"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If STATS mode is on, and STD number mode is on, the modification"
      },
      {
        "type": "text",
        "content": "level is stored in positions 79 and 80 for any lines that are"
      },
      {
        "type": "text",
        "content": "modified during the edit session.  In addition, the modification"
      },
      {
        "type": "text",
        "content": "level is replaced for any record that already has a modification"
      },
      {
        "type": "text",
        "content": "level number that is greater than the number specified.  Normally,"
      },
      {
        "type": "text",
        "content": "the level number is one greater than the largest number found in"
      },
      {
        "type": "text",
        "content": "these columns before editing starts. This command allows you to"
      },
      {
        "type": "text",
        "content": "choose a different number."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If LEVEL number 0 is specified, all lines are reset to LEVEL 0 when"
      },
      {
        "type": "text",
        "content": "the file is saved."
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
