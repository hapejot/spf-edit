{
  "id": "S2R2N306",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE SELECTION LIST",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "This is a primary command. Use this command to save the current select"
      },
      {
        "type": "text",
        "content": "list under a symbolic name for later use."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "SAVELIST [ name ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "SAVELIST presents a panel which requests a LIST NAME (if not provided)"
      },
      {
        "type": "text",
        "content": "and DESCRIPTION. Saved lists are accessed via Option 3.F, GROUP LIST."
      },
      {
        "type": "text",
        "content": "When you invoke GROUP LIST, you get a select list of saved names. You"
      },
      {
        "type": "text",
        "content": "then select the desired name and the associated list is presented."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "SAVELIST project1"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
