{
  "id": "S2R00212",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "SPF/PC COMMAND - LEFT",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- Issue the command with a scroll amount.  Type the command and"
      },
      {
        "type": "text",
        "content": "the amount, or type the amount and press the appropriate PFkey."
      },
      {
        "type": "text",
        "content": "- Change the SCROLL field and execute step 1."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Scroll amounts can be abbreviated. For example, P for PAGE, M"
      },
      {
        "type": "text",
        "content": "for MAX, etc"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "To move left by amount specified in SCROLL field."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "PF10"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "To move left eight columns."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "LEFT 8"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Also, to move left eight columns."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Type 8 in command field, then press PF10."
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
