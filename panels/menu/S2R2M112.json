      {
        "type": "text",
        "content": "Save and lock the profile.  All current modes and options are saved"
      },
      {
        "type": "text",
        "content": "and marked so that they can not be overwritten. Each time that an"
      },
      {
        "type": "text",
        "content": "edit session is begun, the locked profile is re-called exactly as it"
      },
      {
        "type": "text",
        "content": "was when it was locked. Changes made during a new edit session"
      },
      {
        "type": "text",
        "content": "affect only the current edit session, and not subsequent sessions."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Unlock the current edit profile so that it can be changed."
      },
