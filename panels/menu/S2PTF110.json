  "id": "S2PTF110",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "TERMINAL FUNCTION - [END-OF-DATA]",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Jumps the cursor one space to the right of the last non-space,"
      },
      {
        "type": "text",
        "content": "non-null character in the current field."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "[END-OF-DATA]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Positions the cursor at the end of data in the current field,"
      },
      {
        "type": "text",
        "content": "where data consists of anything besides spaces and nulls."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "For example, [END-OF-DATA] would position the cursor at:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "TEST ==> this is some    data, here_"
      },
      {
        "type": "blank"
      },
