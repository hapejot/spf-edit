        "content": "SEARCH SUBDIRECTORIES"
      },
      {
        "type": "text",
        "content": "This field lets you specify whether the search should be limited"
      },
      {
        "type": "text",
        "content": "to the first level of the specified path or to all levels (via"
      },
      {
        "type": "text",
        "content": "recursive search)."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "TEXT"
      },
      {
        "type": "text",
        "content": "Specifies the text string to look for."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "CASE SENSITIVE"
      },
      {
        "type": "text",
        "content": "Specifies whether the TEXT string search should be for an exact"
      },
      {
        "type": "text",
        "content": "match (CASE SENSITIVE = Y), or for a match on upper and lower"
      },
      {
        "type": "text",
        "content": "case characters (CASE SENSITIVE = N)."
