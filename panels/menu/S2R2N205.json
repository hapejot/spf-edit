{
  "id": "S2R2N205",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - LRECL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Used to set the logical record length profile variable."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "LRECL nnn [ TRUNC ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Sets the maximum logical record length for records in a particular"
      },
      {
        "type": "text",
        "content": "file type. You can also set this value with the Profile Option panel"
      },
      {
        "type": "text",
        "content": "0.7."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If you have a corrupted file, and want to truncate records which exceed"
      },
      {
        "type": "text",
        "content": "the desired LRECL, specify TRUNC along with the LRECL value. The TRUNC"
      },
      {
        "type": "text",
        "content": "parameter only applies to the current file in EDIT."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
