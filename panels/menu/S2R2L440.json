{
  "id": "S2R2L440",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - TJ",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Joins the current and following line.  This command is, in effect,"
      },
      {
        "type": "text",
        "content": "the reverse of the Text Split command."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "TJ"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "The TJ command operates within the current bounds.  Data in the next"
      },
      {
        "type": "text",
        "content": "line (being appended) that is outside the current bounds is deleted."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "TJ0402 The text in the following line"
      },
      {
        "type": "text",
        "content": "000403 will be appended"
      },
      {
        "type": "text",
        "content": "000404 to the text in the current line."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Results"
      },
      {
        "type": "text",
        "content": "000402 The text in the following line will be appended"
      },
      {
        "type": "text",
        "content": "000403 to the text in the current line."
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
