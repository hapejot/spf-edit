  "title": {
    "product_var": "ZPRODTSK",
    "text": "SPF/PC COMMAND - SCREEN",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to change the size of the screen."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "SCREEN nn"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "The number of lines specified may not be directly supportable on the"
      },
      {
        "type": "text",
        "content": "displ type that you are using. In that case SPF/PC sets the video"
      },
      {
        "type": "text",
        "content": "mode to the closest valid setting."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "To change your VGA screen to 50 line mode:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SCREEN 50"
      },
      {
        "type": "blank"
      },
