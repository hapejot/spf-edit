{
  "id": "S2R3X00D",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE LIST LINE COMMAND - D",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to delete a file or a subdirectory."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "D"
      },
      {
        "type": "text",
        "content": "DD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Type a 'D' next to the entry you want to delete.  This command, by"
      },
      {
        "type": "text",
        "content": "default, may be use only from 3.4 or 3.X select lists.  The EXTENDED"
      },
      {
        "type": "text",
        "content": "LIND COMMANDS field of panel 0.5 may be toggled to allow this"
      },
      {
        "type": "text",
        "content": "command from any file list."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If you select a subdirectory with D, all the file in the directory"
      },
      {
        "type": "text",
        "content": "and its subdirectories are deleted as well."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "NAME        SIZE    DATE    TIME"
      },
      {
        "type": "text",
        "content": "D  FOO.DOC    12433  01-25-91 10:56a"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
  "proc_section": {
