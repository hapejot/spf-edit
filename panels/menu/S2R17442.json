{
  "id": "S2R17442",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FIND PREFIX PARAMETER",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You use the PREFIX optional parameter of the FIND command to specify"
      },
      {
        "type": "text",
        "content": "that the search argument must be the starting characters of a string.  A"
      },
      {
        "type": "text",
        "content": "prefix is defined as being preceded by a nonalphameric character and"
      },
      {
        "type": "text",
        "content": "followed by an alphameric character."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "COMMAND  find ctc prefix    +       scans for the prefix \"ctc\""
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Only those occurrences of the character string \"ctc\" that are a prefix"
      },
      {
        "type": "text",
        "content": "to a word and that are within the specified columns will be considered a"
      },
      {
        "type": "text",
        "content": "match.  The prefix parameter could be used, for example, to find all"
      },
      {
        "type": "text",
        "content": "words that beginning with \"th\", without finding words ending in \"th\"."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "In the list below, the intensified strings would be found and the non"
      },
      {
        "type": "text",
        "content": "intensified strings would be ignored if the prefix \"at\" were requested"
      },
      {
        "type": "text",
        "content": "in a FIND command."
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "\"PREFIX AT\"   AT"
          },
          {
            "type": "text",
            "content": "ATLANTIC+ BAT  BATS  'AT'  =AT!"
          },
          {
            "type": "text",
            "content": "(ATM)+ (MAT)"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
