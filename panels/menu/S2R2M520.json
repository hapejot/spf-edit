{
  "id": "S2R2M520",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - AUTOLIST",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Turns automatic listing generation on or off."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Creates a source listing after changes have been made and saved."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "AUTOLIST [ON ]"
      },
      {
        "type": "text",
        "content": "[OFF]"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If AUTOLIST is ON when the edit session ends, a listing of the file"
      },
      {
        "type": "text",
        "content": "is generated."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If AUTOLIST is OFF when the edit session ends, a listing of the file"
      },
      {
        "type": "text",
        "content": "is not generated."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
