{
  "id": "S2R00390",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - USER",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to execute a Foreground application, and then"
      },
      {
        "type": "text",
        "content": "return to the current context."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "USER [user-application-name]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command executes a user application.  See FOREGROUND CHAPTER"
      },
      {
        "type": "text",
        "content": "for details on setting up user applications."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "To call the previously defined \"unzip\" FOREGROUND definition,"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "USER unzip"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "To display the Foreground selection list, issue the command:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "USER"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
