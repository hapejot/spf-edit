{
  "id": "S2R2M640",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - MOVE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Moves a file from disk into the current file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "MOVE [filename] [BEFORE label]"
      },
      {
        "type": "text",
        "content": "[AFTER  label]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Works the same as the COPY primary command (see COPY) but it removes"
      },
      {
        "type": "text",
        "content": "the file after it has been copied into the current file.  The source"
      },
      {
        "type": "text",
        "content": "line range parameter is not supported as it is on COPY."
      },
