{
  "id": "S2P05200",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "PRINTER SETUP PANEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "0.2 - PRINTER SETUP PANEL"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The printer setup panel allows you to create multiple printer"
      },
      {
        "type": "text",
        "content": "configurations which can be used to perform different printing"
      },
      {
        "type": "text",
        "content": "roles. Printer setups are symbolically named. DEFPRN, the default,"
      },
      {
        "type": "text",
        "content": "typically performs no formatting functions and is routed to logical"
      },
      {
        "type": "text",
        "content": "device PRN."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You can also change the active printer at any time by issuing the"
      },
      {
        "type": "text",
        "content": "LPRINT primary command. This command is accepted in all panels."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The command:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "LPRINT+[logical-printer-name]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "selects a logical printer, where LPRINT with no parameter displays"
      },
      {
        "type": "text",
        "content": "Panel 0.2."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "1 +- Printer Setup Configurations"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
