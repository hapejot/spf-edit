{
  "id": "S2R01133",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE SELECTION LIST",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "In BROWSE and EDIT you may select one file at a time from the list,"
      },
      {
        "type": "text",
        "content": "either by entering a SELECT command (described below) or by entering"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "the single character"
          },
          {
            "type": "text",
            "content": "S+in front of the file name (see next panel)."
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "The SELECT command (which can be entered as"
          },
          {
            "type": "text",
            "content": "SEL+or"
          },
          {
            "type": "text",
            "content": "S+) may be used to"
          }
        ]
      },
      {
        "type": "text",
        "content": "select a file that is not currently displayed on the list.  This may be"
      },
      {
        "type": "text",
        "content": "done in EDIT to specify a new file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "╔"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "The example to the right     ║"
          },
          {
            "type": "text",
            "content": "COMMAND  sel data.tst"
          }
        ]
      },
      {
        "type": "text",
        "content": "shows how to select file     ║   FILENAME         SIZE      DATE     TIME"
      },
      {
        "type": "text",
        "content": "\"DATA.TST\".                  ║   SOURCE           <DIR>    1-01-80  12:01a"
      },
      {
        "type": "text",
        "content": "║   APPTEST.FIL       5872    7-11-90   3:30p"
      },
      {
        "type": "text",
        "content": "║   BETAZOID.NCC    102376   11-05-89   9:52a"
      },
      {
        "type": "text",
        "content": "║   CTEST1.DAT        7200    5-30-91  10:07a"
      },
      {
        "type": "text",
        "content": "║   CTEST2.DAT       12548    5-30-91   4:36p"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
