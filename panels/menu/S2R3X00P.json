{
  "id": "S2R3X00P",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE LIST LINE COMMAND - P",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to select a file or directory to print."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "P"
      },
      {
        "type": "text",
        "content": "PP"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Type a 'P' next to the file you want to BROWSE.  This command,"
      },
      {
        "type": "text",
        "content": "by default, may be use only from 3.4 or 3.X select lists.  The"
      },
      {
        "type": "text",
        "content": "EXTENDED LIND COMMANDS field of panel 0.5 may be toggled to"
      },
      {
        "type": "text",
        "content": "allow this command from any file list."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If you select a subdirectory with P, its contents are printed.  Use"
      },
      {
        "type": "text",
        "content": "the PP block commands to print adjacent files."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "NAME        SIZE    DATE    TIME"
      },
      {
        "type": "text",
        "content": "P  FOO.DOC    12433  01-25-91 10:56a"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
  "proc_section": {
