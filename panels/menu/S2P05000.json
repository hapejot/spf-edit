      {
        "type": "text",
        "content": "SPF/PC CONFIGURATION PANELS"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "This panel is used to select from the different configuration"
      },
      {
        "type": "text",
        "content": "panels available in SPF/PC. For more information on specific"
      },
      {
        "type": "text",
        "content": "capabilities, select panel by number:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "1 + TERMINAL      - Specify terminal characteristics"
      },
      {
        "type": "text",
        "content": "2 + PRINTER       - Specify printer characteristics"
      },
      {
        "type": "text",
        "content": "3 + PF KEYS       - Specify Program Function Key Values"
      },
      {
        "type": "text",
        "content": "4 + DISPLAY       - Specify screen display attributes"
      },
      {
        "type": "text",
        "content": "5 + OPTIONS       - Specify SPF/PC Environment Options"
      },
      {
        "type": "text",
        "content": "7 + PROFILES      - Display, changem or delete profiles"
      },
      {
        "type": "text",
        "content": "K + KEYBOARD      - Keyboard remapping"
      },
      {
        "type": "text",
        "content": "M + MACROS        - Keyboard macros"
      },
