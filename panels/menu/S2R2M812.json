        "type": "text",
        "content": "To delete all lines that contain a non-ASCII character:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "RESET X             (make all lines visible)"
      },
      {
        "type": "text",
        "content": "EXCLUDE ALL P'.'    (exclude lines with non-ASCII)"
      },
      {
        "type": "text",
        "content": "DELETE ALL X        (delete all excluded lines)"
      },
      {
        "type": "blank"
      },
