{
  "id": "S2R3X00R",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE LIST LINE COMMAND - R",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to rename a file or directory."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "R"
      },
      {
        "type": "text",
        "content": "RR"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Type a 'R' next to the entry you want to rename.  This command, by"
      },
      {
        "type": "text",
        "content": "default, may be use only from 3.4 or 3.X select lists.  The EXTENDED"
      },
      {
        "type": "text",
        "content": "LIND COMMANDS field of panel 0.5 may be toggled to allow this"
      },
      {
        "type": "text",
        "content": "command from any file list."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Use the RR block command form to rename adjacent files."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "NAME        SIZE    DATE    TIME"
      },
      {
        "type": "text",
        "content": "BBB.DOC    12222  01-25-91 10:55a"
      },
      {
        "type": "text",
        "content": "R  FOO.DOC    12433  01-25-91 10:56a"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
