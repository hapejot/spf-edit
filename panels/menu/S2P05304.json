{
  "id": "S2P05304",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "PRINTER SETUP PANEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "PF keys are applied to the active panel.  Not all commands accessed"
      },
      {
        "type": "text",
        "content": "via PF key may operate in all contexts.  For example, editor line"
      },
      {
        "type": "text",
        "content": "commands only operate in the Edit File Display."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Changes to PF key definitions are applied when you press ENTER."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "When a command is executed via PF key, the primary command field"
      },
      {
        "type": "text",
        "content": "value, if present, is passed to the command as a parameter. For"
      },
      {
        "type": "text",
        "content": "example, type 5 in the primary command field, then press P7. This is"
      },
      {
        "type": "text",
        "content": "the equivalent of entering the primary command `UP 5`."
      },
