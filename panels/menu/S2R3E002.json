      {
        "type": "text",
        "content": "FILE TYPES TO DISPLAY"
      },
      {
        "type": "text",
        "content": "Specifies the types of files that are to be displayed.  You can"
      },
      {
        "type": "text",
        "content": "specify `D` for directories only, `F` for files only, or `B` for"
      },
      {
        "type": "text",
        "content": "both files and directories."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SEARCH SUBDIRECTORIES"
      },
      {
        "type": "text",
        "content": "This field lets you specify whether the search should be limited"
      },
      {
        "type": "text",
        "content": "to the first level of the specified path or to all levels (via"
      },
      {
        "type": "text",
        "content": "recursive search)."
