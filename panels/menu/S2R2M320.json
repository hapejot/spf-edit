      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command will blank out STANDARD and COBOL sequence numbers. To"
      },
      {
        "type": "text",
        "content": "blank out sequence numbers when NUMBER mode is off, first enter the"
      },
      {
        "type": "text",
        "content": "NUMBER command with the proper options. Then enter the UNNUM"
      },
      {
        "type": "text",
        "content": "command."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "This command is valid only when NUMBER mode is on."
