      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Specifies whether UNDO support is on or off."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "RECOVERY [ ON | OFF ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If ON is specified, UNDO/REDO support is activated."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If OFF is specified, UNDO/REDO support is de-activated."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "This command is identical to UNDO ON/OFF."
      },
