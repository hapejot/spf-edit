      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Duplicates a block of lines in place as many times as specified."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "RR[number]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command functions identically to the REPEAT line command except"
      },
      {
        "type": "text",
        "content": "it operates on a block of lines rather than a single line.  It is"
      },
      {
        "type": "text",
        "content": "necessary to mark both the beginning and end of the block with `RR`."
      },
