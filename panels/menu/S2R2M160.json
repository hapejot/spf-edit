{
  "id": "S2R2M160",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - CUT",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "To copy or move a block of lines to the cut buffer."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "CUT"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "For CUT to function, you must mark the block of lines to be `cut`"
      },
      {
        "type": "text",
        "content": "with either CC or MM line commands. After the lines have been `cut`,"
      },
      {
        "type": "text",
        "content": "they may be `pasted` into another concurrent edit session.  The last"
      },
      {
        "type": "text",
        "content": "contents of the cut buffer are replaced with the most recent `cut`."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "To cut the block of lines marked with CC or MM:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "CUT"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
