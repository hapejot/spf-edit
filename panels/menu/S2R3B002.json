        "type": "text",
        "content": "PATH"
      },
      {
        "type": "text",
        "content": "Specifies the origin for the search and optionally constrains"
      },
      {
        "type": "text",
        "content": "conformant files to a particular file extension.  Normal files"
      },
      {
        "type": "text",
        "content": "are typically classed by extension. For example, COBOL program"
      },
      {
        "type": "text",
        "content": "source files might have the extension `.COB`."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SEARCH SUBDIRECTORIES"
      },
      {
        "type": "text",
        "content": "This field lets you specify whether the search should be limited"
      },
      {
        "type": "text",
        "content": "to the first level of the specified path or to all levels (via"
      },
      {
        "type": "text",
        "content": "recursive search)."
