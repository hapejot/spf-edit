{
  "id": "S2R00180",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "SPF/PC COMMAND - FSPLIT",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to start a second full screen SPF/PC task. You can"
      },
      {
        "type": "text",
        "content": "also use this command to convert from standard-split mode to"
      },
      {
        "type": "text",
        "content": "full-split mode."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "FSPLIT"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Issuing FSPLIT does one of two things:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- If only one task has been started, SPF/PC saves the current panel,"
      },
      {
        "type": "text",
        "content": "starts a second task, and swaps it into view."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- If a second session has been started, SPF/PC swaps the second"
      },
      {
        "type": "text",
        "content": "session into view in full screen mode."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "To swap back to the first session, enter the SWAP command (normally P9;)."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
