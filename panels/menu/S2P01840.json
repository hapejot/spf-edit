{
  "id": "S2P01840",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "ERASE EOF KEY",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
