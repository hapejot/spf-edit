{
  "id": "S2R3X00I",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE LIST LINE COMMAND - I",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to get attribute information on the selected file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "I"
      },
      {
        "type": "text",
        "content": "II"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Type a 'I' next to the file you want information on.  Another panel"
      },
      {
        "type": "text",
        "content": "with the different attribute fields, hidden, system, read-only is"
      },
      {
        "type": "text",
        "content": "displayed, allowing for modifications."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Use the II block command form to change the attributes of adjacent"
      },
      {
        "type": "text",
        "content": "files."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "NAME        SIZE    DATE    TIME"
      },
      {
        "type": "text",
        "content": "I  FOO.DOC    12433  01-25-91 10:56a"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
