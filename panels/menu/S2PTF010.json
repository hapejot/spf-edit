{
  "id": "S2PTF010",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "TERMINAL FUNCTION - [BACKTAB]",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Jumps the cursor to a previous start of an unprotected field."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "[BACKTAB]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If the cursor is currently in an unprotected field, the cursor"
      },
      {
        "type": "text",
        "content": "is moved to the beginning of that field; if it is already at"
      },
      {
        "type": "text",
        "content": "the beginning of a field, it moves to the beginning of the"
      },
      {
        "type": "text",
        "content": "previous unprotected field (scanning right to left, bottom to"
      },
      {
        "type": "text",
        "content": "top).  If the cursor is at the top of the screen, then it is"
      },
      {
        "type": "text",
        "content": "moved to the last unprotected field on the screen."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
