{
  "id": "S2R17440",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FIND PARAMETERS",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
