{
  "id": "S2R3I000",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "SUPERC PANEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
