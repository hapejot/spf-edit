{
  "id": "S2R2N007",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "GENERAL COMMAND - PANELID",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to toggle the display of the panel ID."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "PANELID [ ON | OFF ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command turns panel ID display ON or OFF. If no parameter is"
      },
      {
        "type": "text",
        "content": "specified, it toggles the present panel ID display state. When panel"
      },
      {
        "type": "text",
        "content": "ID display is ON, the panel ID is displayed in the upper left corner"
      },
      {
        "type": "text",
        "content": "of all SPF/PC panels."
      },
