{
  "id": "S2R3D004",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "COMPLEX SEARCH PANEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "PATH"
      },
      {
        "type": "text",
        "content": "Specifies the origin for the search and optionally constrains"
      },
      {
        "type": "text",
        "content": "conformant files to a particular file extension.  You can"
      },
      {
        "type": "text",
        "content": "specify up to four individual paths, all of which will"
      },
      {
        "type": "text",
        "content": "participate in the search. Paths may specify different drives."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "TEXT"
      },
      {
        "type": "text",
        "content": "Specifies the text string to look for.  You can specify up to"
      },
      {
        "type": "text",
        "content": "four independent text strings.  If ANY of the text strings is"
      },
      {
        "type": "text",
        "content": "found in a particular file, it will appear in the resulting"
      },
      {
        "type": "text",
        "content": "select list."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "CASE SENSE"
      },
      {
        "type": "text",
        "content": "Specifies whether the TEXT string search should be for an exact"
      },
      {
        "type": "text",
        "content": "match (CASE SENSE = Y), or for a match on upper and lower case"
      },
      {
        "type": "text",
        "content": "characters (CASE SENSE = N)."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
