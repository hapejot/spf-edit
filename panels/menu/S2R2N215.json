{
  "id": "S2R2N215",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - SREPLACE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to create or replace an external file with the"
      },
      {
        "type": "text",
        "content": "contents of the selection."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "SREPLACE [ file-name ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Selections are made with the mouse. The selection is not deleted from"
      },
      {
        "type": "text",
        "content": "the file. If you do not specify a name, a dialog panel is presented"
      },
      {
        "type": "text",
        "content": "which enables you to enter the target file name."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If the file already exists, SREPLACE will overwrite it. To avoid"
      },
      {
        "type": "text",
        "content": "overwriting the file, use SCREATE."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
