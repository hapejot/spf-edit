{
  "id": "S2R2N208",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - SAVECOUNT",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to cause files being edited to be automatically saved"
      },
      {
        "type": "text",
        "content": "based on the number of times the SPF-ENTER has been pressed."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "SAVECOUNT nnn"
      },
      {
        "type": "text",
        "content": "SAVEC"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If 0 is specified, files being edited are not automatically saved."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If 1 or greater is specified, files being edited are automatically"
      },
      {
        "type": "text",
        "content": "saved every \"nnn\" presses of SPF-ENTER."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
