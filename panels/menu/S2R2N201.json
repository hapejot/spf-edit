{
  "id": "S2R2N201",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - CHARSET",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Sets the character set to either EBCDIC or ASCII."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "CHARSET [ EBCDIC | ASCII ]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "The character set determines how character code points are interpreted."
      },
      {
        "type": "text",
        "content": "If you download a file from the mainframe without conversion, it will"
      },
      {
        "type": "text",
        "content": "be in EBCDIC. It can be edited without conversion by setting the"
      },
      {
        "type": "text",
        "content": "character set to EBCDIC. DOS files are natively in ASCII. This value"
      },
      {
        "type": "text",
        "content": "can also be set in the file profile via panel 0.7."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
