{
  "id": "S2R2N006",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "GENERAL COMMAND - FSPLIT",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Use this command to start another full screen SPF/PC session."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "FSPLIT"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Issuing FSPLIT saves the current session, starts another session, and"
      },
      {
        "type": "text",
        "content": "swaps it into view. The maximum number of sessions that may be started"
      },
      {
        "type": "text",
        "content": "is set in Terminal Option 0.1."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "To swap among full screen sessions, enter the SWAP command (normally"
      },
      {
        "type": "text",
        "content": "PF 9)."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Once a full screen session is established, it can be split either hori-"
      },
      {
        "type": "text",
        "content": "zontally or vertically."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Hit"
          },
          {
            "type": "text",
            "content": "ENTER+to return to previous menu)"
          }
        ]
      }
    ]
  },
