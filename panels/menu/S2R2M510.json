{
  "id": "S2R2M510",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - AUTONUM",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "menu",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Turns automatic renumbering ON or OFF."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "AUTONUM  [ON ]"
      },
      {
        "type": "text",
        "content": "AUTO     [OFF]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If AUTONUM is on and NUMBER is on, lines will be renumbered when the"
      },
      {
        "type": "text",
        "content": "file is saved."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If AUTONUM is off or NUMBER is off, lines will not be renumbered"
      },
      {
        "type": "text",
        "content": "when the file is saved."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
