        "type": "blank"
      },
      {
        "type": "text",
        "content": "The FIND and RFIND commands normally search for the specified character"
      },
      {
        "type": "text",
        "content": "string from the current cursor location towards the end of the file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You can alter this default behavior by using one of the following"
      },
      {
        "type": "text",
        "content": "parameters:"
      },
      {
        "type": "text",
        "content": "NEXT     PREV     FIRST     LAST    ALL"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "COMMAND  find ctc prev              +scans for the previous \"ctc\""
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The following topics may be selected by number:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "1 + USING THE NEXT PARAMETER"
      },
      {
        "type": "text",
        "content": "2 + USING THE PREV PARAMETER"
      },
      {
        "type": "text",
        "content": "3 + USING THE FIRST PARAMETER"
      },
      {
        "type": "text",
        "content": "4 + USING THE LAST PARAMETER"
      },
      {
        "type": "text",
        "content": "5 + USING THE ALL PARAMETER"
      },
