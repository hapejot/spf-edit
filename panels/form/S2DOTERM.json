        "rules": [
          {
            "type": "non_blank"
          }
        ]
      },
      {
        "field": "ZSF",
        "rules": [
          {
            "type": "non_blank"
          },
          {
            "type": "numeric"
          }
        ]
      },
      {
        "field": "ZKEYRATE",
