          {
            "type": "non_blank"
          },
          {
            "type": "numeric",
            "range": {
              "min": 0,
              "max": 4
            }
          }
        ]
      },
      {
        "field": "ZCSROVR",
        "rules": [
          {
            "type": "non_blank"
          },
          {
            "type": "numeric",
            "range": {
              "min": 0,
              "max": 100
            }
          }
        ]
      },
      {
        "field": "ZCSRINS",
