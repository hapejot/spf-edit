          {
            "type": "non_blank"
          },
          {
            "type": "numeric",
            "range": {
              "min": 0,
              "max": 100
            }
          }
        ]
      },
      {
        "field": "ZPERSINS",
        "rules": [
          {
            "type": "non_blank"
          },
          {
            "type": "boolean"
          }
        ]
      },
      {
        "field": "ZARROWS",
        "rules": [
          {
            "type": "non_blank"
          },
          {
            "type": "boolean"
          }
        ]
      },
      {
        "field": "ZMOUSE",
        "rules": [
          {
            "type": "non_blank"
          },
          {
            "type": "boolean"
          }
        ]
      },
      {
        "field": "ZTIMEDIS",
        "rules": [
          {
            "type": "non_blank"
          },
          {
            "type": "list",
            "values": [
              "B",
              "T",
              "D",
              "N"
            ]
          }
        ]
      },
      {
        "field": "ZMAXTASK",
        "rules": [
          {
            "type": "non_blank"
          },
          {
            "type": "numeric",
            "range": {
              "min": 1,
              "max": 999
            }
          }
        ]
      }
    ]
  },
