          {
            "type": "input",
            "variable": "Z",
            "width": 1,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (N- None, L- Logical)"
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "TAB STOPS AT"
          },
          {
            "type": "input",
            "variable": "CTABSAT",
            "width": 46,
            "field_connector": true
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "LOGICAL TAB CHARACTER"
