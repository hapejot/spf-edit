          {
            "type": "input",
            "variable": "Z",
            "width": 1,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (Y- Merge copy-books, N- don't merge)"
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "COPY-BOOK EXTENSION"
          },
          {
            "type": "input",
            "variable": "Z",
            "width": 3,
            "field_connector": true
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "COPY-BOOK PATH"
          },
          {
            "type": "input",
            "variable": "CCOPYPAT",
            "width": 46,
            "field_connector": true
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "CAPS MODE"
          },
          {
            "type": "input",
            "variable": "Z",
            "width": 1,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (Y- All Caps, N- Mixed Case)"
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "IMBEDDED LANGUAGE(S)"
          },
          {
            "type": "input",
            "variable": "CIMBEDDD",
            "width": 46,
            "field_connector": true
          }
        ]
      },
      {
        "type": "text",
        "content": "(Any of: CICS and SQL)"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "ENTER KEY STYLE"
          },
          {
            "type": "input",
            "variable": "Z",
            "width": 1,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (3- 3270 Style, 2- SPF/PC 2.1 Style,"
          }
        ]
      },
      {
        "type": "text",
        "content": "S- Right-Ctrl/Enter Swapped)"
      }
    ]
