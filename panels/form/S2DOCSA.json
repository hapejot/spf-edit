          {
            "type": "input",
            "variable": "Z",
            "width": 1,
            "field_connector": true
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "QUOTE CHARACTER"
          },
          {
            "type": "input",
            "variable": "Z",
            "width": 1,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (' or \")"
