          {
            "type": "output",
            "variable": "ZMAXLREC"
          },
          {
            "type": "text",
            "content": ")"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "S+- Select file from selection list for conversion."
      }
    ]
  },
