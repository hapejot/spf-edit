      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SOURCE FILE:"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "NAME"
          },
          {
            "type": "input",
            "variable": "ZPATH0",
            "field_connector": true
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "PROFILE"
          },
          {
            "type": "input",
            "variable": "ZPROFIL0",
            "width": 9,
            "field_connector": true
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "DESTINATION FILE:"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "NAME"
          },
          {
            "type": "input",
            "variable": "ZPATH1",
            "field_connector": true
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "PROFILE"
          },
          {
            "type": "input",
            "variable": "ZPROFIL1",
            "width": 9,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+ (Leave blank to use profile based upon"
          }
        ]
      },
      {
        "type": "text",
        "content": "extension)"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "MAX LRECL"
