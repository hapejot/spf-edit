{
  "id": "S2DSLCVT",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "SUPER LIST: FILE CONVERSION",
    "version_var": "ZSHRTVER"
  },
  "type": "form",
  "body": {
    "rows": [
