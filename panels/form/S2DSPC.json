            "type": "text",
            "content": "+NEW FILE: NAME    _SPCNFILE"
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "PROFILE"
          },
          {
            "type": "input",
            "variable": "SPCNPROF",
            "width": 8,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (Blank defaults to file extension)"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "inline_group",
        "fields": [
          {
            "type": "text",
            "content": "+OLD FILE: NAME    _SPCOFILE"
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "PROFILE"
          },
          {
            "type": "input",
            "variable": "SPCOPROF",
            "width": 8,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+    (Blank defaults to file extension)"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "COMPARE TYPE"
          },
          {
            "type": "input",
            "variable": "SPCCOMPT",
            "width": 14,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+ (FILE/LINE/BYTE)"
          }
        ]
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "LISTING TYPE"
          },
          {
            "type": "input",
            "variable": "SPCLISTT",
            "width": 14,
            "field_connector": true
          },
          {
            "type": "text",
            "content": "+ (OVSUM/DELTA/CHANGE/LONG)"
          }
        ]
      },
      {
        "type": "blank"
      },
