        "type": "text",
        "content": "OUTPUT (BROWSE/PRINTER/filename):"
      },
      {
        "type": "inline_group",
        "fields": [
          {
            "type": "text",
            "content": "_SPCOUTPT"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "PROCESS OPTIONS (ANYC | COBOL | STD):"
      },
      {
        "type": "inline_group",
        "fields": [
          {
            "type": "text",
            "content": "_SPCPROPT"
          }
        ]
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
