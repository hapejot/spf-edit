{
  "id": "S2DSPC",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "SUPERC FILE COMPARISON UTILITY",
    "version_var": "ZSHRTVER"
  },
  "type": "form",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
