            "type": "text",
            "content": "&"
          },
          {
            "type": "output",
            "variable": "ZSPFPATH"
          },
          {
            "type": "text",
            "content": "+:"
          },
          {
            "type": "output",
            "variable": "ZSPFPATH"
          }
        ]
      },
      {
        "type": "blank"
