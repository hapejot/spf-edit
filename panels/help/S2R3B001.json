        "type": "blank"
      },
      {
        "type": "text",
        "content": "FILE SEARCH PANEL"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "This panel allows you to search for files, at one or more levels,"
      },
      {
        "type": "text",
        "content": "from a specific path origin.  The resulting select list contains all"
      },
      {
        "type": "text",
        "content": "files at all levels that meet the file specification criteria."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Individual fields are explained below:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "SYSTEM CUR DIR"
      },
      {
        "type": "text",
        "content": "Identifies the current directory. This field only applies when"
      },
      {
        "type": "text",
        "content": "the path specification does not proceed from the root directory."
      },
      {
        "type": "text",
        "content": "For example, if you specified `C:\\FOO` the search for `FOO`"
      },
      {
        "type": "text",
        "content": "would begin in the root directory of drive `C`."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If you specified simply `FOO` the search for `FOO` would begin"
      },
      {
        "type": "text",
        "content": "in the current directory."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
