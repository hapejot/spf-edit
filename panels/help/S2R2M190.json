{
  "id": "S2R2M190",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - ERRORFILE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "This command merges the content of a compiler error message file"
      },
      {
        "type": "text",
        "content": "with the file being edited."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "ERRORFILE [filename]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Error messages are merged as NOTEs into the file being edited at the"
      },
      {
        "type": "text",
        "content": "line position where the error occurred. You can also use the /R"
      },
      {
        "type": "text",
        "content": "command line option to merge compiler error messages with the"
      },
      {
        "type": "text",
        "content": "associated source file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The following message formats are supported:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Micro Focus COBOL, Realia COBOL, Borland C, Zortech C,"
      },
      {
        "type": "text",
        "content": "Microsoft (all languages)"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
