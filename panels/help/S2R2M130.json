{
  "id": "S2R2M130",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - LOCATE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Used to position the file to a specific line number or a specific"
      },
      {
        "type": "text",
        "content": "type of generic line."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "LOCATE {line-number}"
      },
      {
        "type": "text",
        "content": "LOC    {label      }"
      },
      {
        "type": "text",
        "content": "L"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "LOCATE [NEXT  ] [LABEL   ] [range]"
      },
      {
        "type": "text",
        "content": "LOC    [PREV  ] [COMMAND ]"
      },
      {
        "type": "text",
        "content": "L      [FIRST ] [ERROR   ]"
      },
      {
        "type": "text",
        "content": "[LAST  ] [CHANGE  ]"
      },
      {
        "type": "text",
        "content": "[SPECIAL ]"
      },
      {
        "type": "text",
        "content": "[EXCLUDED]"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "The first format scrolls the file so that the line with the"
      },
      {
        "type": "text",
        "content": "specified line number or label is at the top of the display."
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+to continue)"
          }
        ]
      }
    ]
  },
  "metadata": {
    "source_file": "S2R2M130.PAN",
