      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Find the last occurrence of string `ABC`:"
      },
      {
        "type": "text",
        "content": "FIND ABC LAST"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
