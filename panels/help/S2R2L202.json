{
  "id": "S2R2L202",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - BNDS",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "When scrolling, a left scroll stops at the left bound, and a right"
      },
      {
        "type": "text",
        "content": "scroll stops at the right bound. A subsequent left or right scroll"
      },
      {
        "type": "text",
        "content": "goes beyond the bounds if they are not at the end of the line."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Use the RESET primary command, or the D line command to remove the"
      },
      {
        "type": "text",
        "content": "=BNDS> line from the display."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You can also change the bounds with the BOUNDS primary command.  For"
      },
      {
        "type": "text",
        "content": "additional information, see BOUNDS."
      },
      {
        "type": "blank"
