{
  "id": "S2R2L410",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - TABS",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Displays or modifies the current tab settings."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "TABS"
      },
      {
        "type": "text",
        "content": "TAB"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Hardware tab stops are defined with the asterisk (*) character on"
      },
      {
        "type": "text",
        "content": "the TABS line.  Each time the TAB key is pressed, the cursor is"
      },
      {
        "type": "text",
        "content": "advanced to one position to the right of the next hardware tab stop."
      },
      {
        "type": "text",
        "content": "If the cursor is in the line command field, it will position to column"
      },
      {
        "type": "text",
        "content": "1.  This function only works when tabs are set ON."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "When data is entered with an initial logical tab character, it is"
      },
      {
        "type": "text",
        "content": "position one character to the right of the next hardware tab stop."
      },
      {
        "type": "text",
        "content": "This function only works when tabs are set ON and a logical tab"
      },
      {
        "type": "text",
        "content": "character has been defined with the TABS primary command."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
