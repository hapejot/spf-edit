{
  "id": "S2R2M820",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - SORT",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Performs two kinds of sorting:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- sorts full records"
      },
      {
        "type": "text",
        "content": "- sorts individual columns of data without affecting the remainder"
      },
      {
        "type": "text",
        "content": "of the record"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "SORT [range] [X ] [[A] sort-field 1 ... [A] sort-field n]"
      },
      {
        "type": "text",
        "content": "[NX]  [D]                  [D]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "If you specify a range, only the lines within that range will be"
      },
      {
        "type": "text",
        "content": "sorted. To do this, label the first and last lines. Then use these"
      },
      {
        "type": "text",
        "content": "labels in a range specification. See RANGE SEARCH for information on"
      },
      {
        "type": "text",
        "content": "how to specify labels.  Sort can also be limited to excluded (X) or"
      },
      {
        "type": "text",
        "content": "non-excluded (NX) lines."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
