{
  "id": "S2R2M214",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - FIND",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- search for hexadecimal strings, see HEX STRINGS."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- find a line containing string that you just specified in a"
      },
      {
        "type": "text",
        "content": "previous FIND, CHANGE, EXCLUDE command, see ASTERISK STRINGS."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- match strings dependent on its location within a word, see"
      },
      {
        "type": "text",
        "content": "STRING MATCHING PARMS."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- change the direction of searching, see DIR SEARCH."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- restrict searching to a range of lines, see RANGE SEARCH."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- affect searching by whether lines are currently `excluded` or"
      },
      {
        "type": "text",
        "content": "not, see SEARCH EXCLUDED."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Example"
      },
      {
        "type": "text",
        "content": "Find the next occurrence of string `ABC` starting at the current"
      },
      {
        "type": "text",
        "content": "cursor position:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "FIND ABC"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
  "metadata": {
    "source_file": "S2R2M214.PAN",
