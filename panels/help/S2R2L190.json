      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "B is used in conjunction with MOVE/COPY/PASTE primary and line"
      },
      {
        "type": "text",
        "content": "commands to indicate the destination of the data.  This command is"
      },
      {
        "type": "text",
        "content": "not valid on the top of data line, but it is valid on the bottom of"
      },
      {
        "type": "text",
        "content": "data line."
