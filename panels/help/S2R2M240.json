{
  "id": "S2R2M240",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - EXCLUDE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Allows you to exclude selected lines from view."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "EXCLUDE str1 [range][NEXT ][CHARS ][col1[col2]]"
      },
      {
        "type": "text",
        "content": "EX                  [ALL  ][PREFIX]"
      },
      {
        "type": "text",
        "content": "X                   [FIRST][SUFFIX]"
      },
      {
        "type": "text",
        "content": "[LAST ][WORD  ]"
      },
      {
        "type": "text",
        "content": "[PREV ]"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "Excludes one or more lines containing str1.  String edge"
      },
      {
        "type": "text",
        "content": "characteristics may also be specified.  The number of lines excluded"
      },
      {
        "type": "text",
        "content": "is controlled by the search direction and scope.  The search for"
      },
      {
        "type": "text",
        "content": "str1 can be limited to a range of lines."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Parameters may be entered in any order.  One exception is that col1"
      },
      {
        "type": "text",
        "content": "must precede col2."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The lines containing a match on str1 are excluded from view just as"
      },
      {
        "type": "text",
        "content": "if an X line command was entered on those lines."
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
  "metadata": {
