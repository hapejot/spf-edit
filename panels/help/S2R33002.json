{
  "id": "S2R33002",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "MOVE/COPY UTILITY PANEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "For Example:"
      },
      {
        "type": "text",
        "content": "FROM FILE:"
      },
      {
        "type": "text",
        "content": "NAME ===> *.CBL"
      },
      {
        "type": "text",
        "content": "TO FILE:"
      },
      {
        "type": "text",
        "content": "NAME ===> *.COB"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "In this example as the *.CBL files are moved or copied, they are"
      },
      {
        "type": "text",
        "content": "renamed to *.COB."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Individual fields are explained below. For more information on using"
      },
      {
        "type": "text",
        "content": "the FROM FILE/TO FILE fields, see FILENAMES."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "OPTION"
      },
      {
        "type": "text",
        "content": "Specify the desired action in the OPTION field:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "M+- Moves files from one directory to another.  Files within the"
      },
      {
        "type": "text",
        "content": "FROM directory are moved.  Subdirectories within the FROM"
      },
      {
        "type": "text",
        "content": "directory are not moved."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
