{
  "id": "S2R2M810",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT PRIMARY COMMAND - DELETE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Removes one or more lines from the file being edited."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "DELETE ALL  {X } [range]"
      },
      {
        "type": "text",
        "content": "DEL         {NX}"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "You can delete one of the following:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- All excluded lines (DELETE ALL X)."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- All non-excluded lines (DELETE ALL NX)."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- Lines within a range (DELETE ALL .B .E)"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- Excluded lines within a range (DELETE ALL X .B .E)"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "- Non-excluded lines within a range (DELETE ALL NX .B .E)"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
