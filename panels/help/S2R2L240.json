      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Deletes one or more lines from the file."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "D[number]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "D alone deletes a single line."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "A number may follow the delete command. This will delete the"
      },
      {
        "type": "text",
        "content": "specified number of following, consecutive lines. For example, D3"
      },
      {
        "type": "text",
        "content": "will delete three lines."
      },
