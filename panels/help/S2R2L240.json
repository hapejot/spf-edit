  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - D",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
