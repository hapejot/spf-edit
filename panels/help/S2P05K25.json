{
  "id": "S2P05K25",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "ASSIGNING VALUES TO KEYS",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Key macros, which are recorded sequences of key/mouse events,"
      },
      {
        "type": "text",
        "content": "may also be mapped to any key.  For example, to assign the"
      },
      {
        "type": "text",
        "content": "previously recorded key macro \"COMMENT\" to the Alt-C key,"
      },
      {
        "type": "text",
        "content": "make the following changes."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "NAME             VALUE"
      },
      {
        "type": "text",
        "content": "Alt-C+           [KEY-MACRO COMMENT]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Once assigned, pressing the Alt-C will start playback of the"
      },
      {
        "type": "text",
        "content": "recorded key events in the COMMENT macro."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "See KEY MACROS for more information."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
