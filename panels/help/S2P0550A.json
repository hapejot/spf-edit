{
  "id": "S2P0550A",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDITOR OPTIONS PANEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "EDIT READ-ONLY FILES+  Specifies whether you want to be able to edit"
      },
      {
        "type": "text",
        "content": "read-only files. In this case, EDIT loads the file and allows all"
      },
      {
        "type": "text",
        "content": "functions of EDIT to operate in the normal manner but will not allow"
      },
      {
        "type": "text",
        "content": "you to save the file. This is handy when you want to examine a file"
      },
      {
        "type": "text",
        "content": "which has the read-only attribute and you want to perform operations"
      },
      {
        "type": "text",
        "content": "which are not available in BROWSE."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Y+- Allow edit of read-only files."
      },
      {
        "type": "text",
        "content": "N+- Do not allow edit of read-only files."
      },
      {
        "type": "blank"
      },
