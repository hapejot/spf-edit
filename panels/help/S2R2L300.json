{
  "id": "S2R2L300",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - LCC",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Converts alphabetic characters within a block of lines to lowercase"
      },
      {
        "type": "text",
        "content": "letters."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "LCC"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command functions identically to the LOWER CASE line command"
      },
      {
        "type": "text",
        "content": "except it operates on a block of lines rather than a single line."
      },
      {
        "type": "text",
        "content": "It is necessary to mark both the beginning and end of the block with"
      },
      {
        "type": "text",
        "content": "`LCC`."
      },
