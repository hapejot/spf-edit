{
  "id": "S2R17100",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "BROWSE",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The LOCATE command is used to scroll to a specific line in a file being"
      },
      {
        "type": "text",
        "content": "browsed."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "COMMAND  locate 450            + displays relative line 450"
      },
      {
        "type": "text",
        "content": "COMMAND  loc .err              + displays line labeled \".ERR\""
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The parameter can be either a line number or a label that has"
      },
      {
        "type": "text",
        "content": "been previously assigned."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "LOCATE 0 can be entered to scroll to the top of the data.  LOCATE 999999"
      },
      {
        "type": "text",
        "content": "can be entered to scroll to the bottom of the data."
      },
      {
        "type": "blank"
      },
      {
