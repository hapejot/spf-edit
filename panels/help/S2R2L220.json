{
  "id": "S2R2L220",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - CC",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Copies a block of lines to another position within the current file."
      },
      {
        "type": "text",
        "content": "It is also used with CREATE/REPLACE/CUT primary commands to copy"
      },
      {
        "type": "text",
        "content": "lines between files."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "CC"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command functions identically to the COPY line command except"
      },
      {
        "type": "text",
        "content": "it operates on a block of lines rather than a single line.  It is"
      },
      {
        "type": "text",
        "content": "necessary to mark both the beginning and end of the block with `CC`."
      },
      {
        "type": "blank"
      },
