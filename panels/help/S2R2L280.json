{
  "id": "S2R2L280",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - L",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Displays the last excluded line, or the last N excluded lines of an"
      },
      {
        "type": "text",
        "content": "excluded block."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "L[number]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command may be specified with or without a number.  If no"
      },
      {
        "type": "text",
        "content": "number is specified, the last line of the excluded block is display"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "This command may be validly entered only on the excluded line"
      },
      {
        "type": "text",
        "content": "indicator. If it is entered on any other line, an error message will"
      },
      {
        "type": "text",
        "content": "be displayed."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
