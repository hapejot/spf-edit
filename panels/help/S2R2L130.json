{
  "id": "S2R2L130",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - >>",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Shifts a block of lines of the body of a computer program to the"
      },
      {
        "type": "text",
        "content": "right without affecting program labels or comments."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": ">>[number]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command functions identically to the > line command except it"
      },
      {
        "type": "text",
        "content": "operates on a block of lines rather than a single line.  It is"
      },
      {
        "type": "text",
        "content": "necessary to mark both the beginning and end of the block with `>>`."
      },
      {
        "type": "blank"
      },
