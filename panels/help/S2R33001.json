      {
        "type": "text",
        "content": "MOVE/COPY UTILITY PANEL"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "This panel allows you to move or copy a files and/or directories."
      },
      {
        "type": "text",
        "content": "You can move or copy from one directory to another on the same drive"
      },
      {
        "type": "text",
        "content": "or different drives."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "You can use wild-card characters (* and ?) in the from fields, to"
      },
      {
        "type": "text",
        "content": "fields, or both, to specify a group of files:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Typically you copy FROM files intact to the TO directory. In this"
      },
      {
        "type": "text",
        "content": "case you specify the FROM NAME field and LEAVE the TO name field"
      },
      {
        "type": "text",
        "content": "blank."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If you want to rename files as they are copied or moved, you specify"
      },
      {
        "type": "text",
        "content": "the FROM NAME field with a particular extension and the TO NAME"
      },
      {
        "type": "text",
        "content": "field with a different extension."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
