{
  "id": "S2R2L470",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "EDIT LINE COMMAND - UCC",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Purpose"
      },
      {
        "type": "text",
        "content": "Converts alphabetic characters within a block of lines to uppercase"
      },
      {
        "type": "text",
        "content": "letters."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Format"
      },
      {
        "type": "text",
        "content": "UCC"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Remarks"
      },
      {
        "type": "text",
        "content": "This command functions identically to the UPPER CASE line command"
      },
      {
        "type": "text",
        "content": "except it operates on a block of lines rather than a single line."
      },
      {
        "type": "text",
        "content": "It is necessary to mark both the beginning and end of the block with"
      },
      {
        "type": "text",
        "content": "`UCC`."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
