{
  "id": "S2R34002",
  "title": {
    "product_var": "ZPRODTSK",
    "text": "FILE LIST UTILITY PANEL",
    "version_var": "ZSHRTVER",
    "prefix": "HELP"
  },
  "type": "help",
  "body": {
    "rows": [
      {
        "type": "command",
        "variable": "ZCMD"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Use wild-card characters (* and ?) in the file selection fields to"
      },
      {
        "type": "text",
        "content": "specify a group of files:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "The sample panel above would result in SPF/PC displaying a select"
      },
      {
        "type": "text",
        "content": "list of all files in the c:\\TEST directory.  You could then use"
      },
      {
        "type": "text",
        "content": "select list line commands to work with this group of files."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "If you wanted to be more specific, you could specify *.COB in the"
      },
      {
        "type": "text",
        "content": "NAME field.  SPF/PC would then display a select list containing only"
      },
      {
        "type": "text",
        "content": "files with the COB extension."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "Individual fields are explained below."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "OPTION"
      },
      {
        "type": "text",
        "content": "This is a standard command field, where you can enter SPF/PC"
      },
      {
        "type": "text",
        "content": "general commands.  Line commands are only available in the"
      },
      {
        "type": "text",
        "content": "select list."
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "blank"
      },
      {
        "type": "field_row",
        "fields": [
          {
            "type": "text",
            "content": "(Press"
          },
          {
            "type": "text",
            "content": "ENTER+for next page)"
          }
        ]
      }
    ]
  },
