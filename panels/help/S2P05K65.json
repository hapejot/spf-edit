      {
        "type": "text",
        "content": "The newly updated custom key mapping table should display:"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "NAME                    VALUE"
      },
      {
        "type": "text",
        "content": "Big-Enter               [ENTER-3270]"
      },
      {
        "type": "text",
        "content": "Ctrl Numeric-5          [DEL-END-OF-DATA]"
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "To change the value of a custom key that has already been"
      },
      {
        "type": "text",
        "content": "defined, select it by using the 'E' line command in the field"
      },
      {
        "type": "text",
        "content": "to the left of the keys name."
      },
      {
        "type": "blank"
      },
      {
        "type": "text",
        "content": "To delete existing custom key definitions, use the 'D' line"
      },
      {
        "type": "text",
        "content": "command."
